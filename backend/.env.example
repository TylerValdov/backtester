# ── Backtester backend configuration ──────────────────────────────────────────
# Copy to `.env` and fill in real values. Everything works out of the box with
# defaults (synthetic data, console email, SQLite) — keys below switch on real
# integrations.

# Secret used to sign session JWTs. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-dev-secret

# Fernet key for encrypting stored provider API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# PLACEHOLDER[TIMESCALEDB/POSTGRES]: swap for a time-series optimized store in
# production, e.g. postgresql+psycopg://user:pass@host:5432/backtester
# The ohlcv access layer is isolated in app/data/ so only that module changes.
DATABASE_URL=sqlite:///./backtester.db

# ── Market data (historical + live) ──────────────────────────────────────────
# PLACEHOLDER[MARKET DATA API]: Polygon.io / Alpaca / Yahoo Finance key.
# When set, app/data/provider.py:PolygonProvider is used instead of the
# deterministic synthetic generator. Expected data shape: daily OHLCV bars
# {date, open, high, low, close, volume} per symbol.
MARKET_DATA_PROVIDER=synthetic
MARKET_DATA_API_KEY=

# ── ML model inference ────────────────────────────────────────────────────────
# PLACEHOLDER[ML INFERENCE ENDPOINT]: HTTP endpoint for custom model scoring.
# POST {features: {symbol: [[...]], ...}} -> {scores: {symbol: [..], ...}}
ML_INFERENCE_URL=

# ── Task queue ────────────────────────────────────────────────────────────────
# PLACEHOLDER[CELERY+REDIS]: broker URL for distributed backtest workers, e.g.
# redis://localhost:6379/0. Unset = in-process thread pool (app/tasks.py).
CELERY_BROKER_URL=

# ── Email (confirmation + notifications) ──────────────────────────────────────
# PLACEHOLDER[EMAIL SERVICE]: Resend / Postmark / SES API key. Unset = links
# are logged to the server console and returned in dev responses.
EMAIL_API_KEY=
EMAIL_FROM=research@backtester.local

# ── Google OAuth ──────────────────────────────────────────────────────────────
# PLACEHOLDER[GOOGLE OAUTH]: credentials from console.cloud.google.com.
# Redirect URI to register: http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Frontend origin (cookie/redirect target)
FRONTEND_ORIGIN=http://localhost:3000
