# == Deployment configuration (docker compose) =================================
# Copy to `.env` (kept out of git) and fill in. Used by docker-compose.yml.

# Public hostname. A real DNS name (e.g. app.example.com) makes Caddy obtain a
# TLS cert automatically. Use ":80" for plain-HTTP local testing.
DOMAIN=app.example.com

# Must match the public origin the browser uses (scheme + host, no trailing /).
FRONTEND_ORIGIN=https://app.example.com

# == Database (Postgres) =======================================================
POSTGRES_USER=backtester
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=backtester
# DATABASE_URL is assembled from the three values above in docker-compose.yml.

# == Secrets ===================================================================
# Reuse the long values already in backend/.env, or generate fresh:
#   SECRET_KEY:     python -c "import secrets; print(secrets.token_hex(32))"
#   ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
ENCRYPTION_KEY=

# Session cookie Secure flag. TRUE is correct in production (served over HTTPS by
# Caddy) -- the localhost dev issue that required false only happens over plain
# HTTP. Set false only if you deploy DOMAIN=:80 without TLS.
COOKIE_SECURE=true

# == Market data ===============================================================
MARKET_DATA_PROVIDER=alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_FEED=iex
ALPACA_HISTORY_START=2015-01-01

# == Email (Resend) ============================================================
RESEND_API_KEY=
EMAIL_FROM="Backtester <verify@yourdomain.com>"

# == Optional ==================================================================
ML_INFERENCE_URL=
